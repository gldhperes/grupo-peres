n                            <a href=\"#\">Peres Segurança</a>\r\n                        </li>\r\n                        <li>\r\n                            <ion-icon name=\"caret-forward-outline\"></ion-icon>\r\n                            <a href=\"#\">Peres Serviços</a>\r\n                        </li>\r\n                        <li>\r\n                            <ion-icon name=\"caret-forward-outline\"></ion-icon>\r\n                            <a href=\"#\">Genial Serviços</a>\r\n                        </li>\r\n                        <li>\r\n                            <ion-icon name=\"caret-forward-outline\"></ion-icon>\r\n                            <a href=\"#\">P3 Segurança Eletrônica</a>\r\n                        </li>\r\n                    </ul>\r\n                </li>\r\n\r\n                <li>\r\n                    <h3>Serviços</h3>\r\n\r\n                    <ul className=\"dropdown\">\r\n                        <li>\r\n                            <ion-icon name=\"caret-forward-outline\"></ion-icon>\r\n                            <a href=\"#\">Segurança Patrimonial</a>\r\n                        </li>\r\n                        <li>\r\n                            <ion-icon name=\"caret-forward-outline\"></ion-icon>\r\n                            <a href=\"#\">Eventos</a>\r\n                        </li>\r\n                        <li>\r\n                            <ion-icon name=\"caret-forward-outline\"></ion-icon>\r\n                            <a href=\"#\">Segurança Eletrônica</a>\r\n                        </li>\r\n                    </ul>\r\n                </li>\r\n\r\n                <li>\r\n                    <h3>Segmentos</h3>\r\n\r\n                    <ul className=\"dropdown\">\r\n                        <li>\r\n                            <ion-icon name=\"caret-forward-outline\"></ion-icon>\r\n                            <a href=\"#\">Serviços 1</a>\r\n                        </li>\r\n                        <li>\r\n         